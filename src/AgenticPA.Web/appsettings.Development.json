{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Agent": {
    "Endpoint": "https://api.openai.com/v1",
    "Model": "gpt-4o",
    "ApiKey": "set-via-user-secrets-or-env"
  },
  "Mcp": {
    "Url": "http://localhost:7070/"
  },
  "Rubric": {
    "Refresh": {
      "Enabled": true,
      "WindowStartHour": 2,
      "WindowEndHour": 4,
      "PollIntervalSeconds": 300,
      "QuiescePeriodSeconds": 60,
      "AlwaysReloadFromDisk": true
    }
  }
}
