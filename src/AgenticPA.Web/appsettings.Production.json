{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Agent": {
    "Provider": "OpenAI",
    "Endpoint": "https://api.openai.com/v1",
    "Model": "gpt-4o"
  },
  "Mcp": {
    "Url": "http://mcp:7070/"
  },
  "Rubric": {
    "Refresh": {
      "Enabled": true,
      "WindowStartHour": 2,
      "WindowEndHour": 4,
      "PollIntervalSeconds": 300,
      "QuiescePeriodSeconds": 60,
      "AlwaysReloadFromDisk": false
    }
  }
}
